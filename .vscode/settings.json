{
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.import.gradle.enabled": true,
  "java.import.gradle.wrapper.enabled": true,
  "java.import.exclusions": [
    "**/node_modules/**",
    "**/.gradle/**",
    "**/build/**"
  ],
  "java.project.resourceFilters": [
    "node_modules",
    ".gradle",
    "build"
  ],
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.gradle/**": true,
    "**/build/**": true,
    "**/*.log": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.gradle": true,
    "**/build": true,
    "**/*.log": true
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/.gradle": true,
    "**/build": true,
    "**/*.log": true
  }
}
